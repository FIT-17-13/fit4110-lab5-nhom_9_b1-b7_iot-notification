# ========================
# Cấu hình chung
# ========================
ENV=local
AUTH_TOKEN=local-dev-token

# ========================
# B1: IoT Ingestion Config
# ========================
IOT_API_PORT=8000
IOT_SERVICE_VERSION=v0.1.0-team9-iot

POSTGRES_USER=lab05
POSTGRES_PASSWORD=lab05pass
POSTGRES_DB=iotdb
# Connection string cho code Python của IoT kết nối DB
DATABASE_URL=postgresql://${POSTGRES_USER}:${POSTGRES_PASSWORD}@postgres-db:5432/${POSTGRES_DB}

# ========================
# B7: Notification Config
# ========================
NOTIFY_API_PORT=8001
NOTIFY_SERVICE_VERSION=v0.1.0-team9-notify

RABBITMQ_USER=notify_admin
RABBITMQ_PASSWORD=secret_mq_password
# Connection string cho code Python của Notify kết nối RabbitMQ
RABBITMQ_URL=amqp://${RABBITMQ_USER}:${RABBITMQ_PASSWORD}@rabbitmq:5672/

# Secrets (Chỉ để mẫu, không điền token thật vào đây, nhớ dặn nhóm copy sang file .env ẩn)
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
SMTP_PASSWORD=your_email_app_password_here